{
  "expo": {
    "name": "FoodLodge",
    "slug": "foodlodge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#f5c842"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.foodlodge",
      "config": {
        "googleMapsApiKey": "AIzaSyBXwuaCqvL03XGToZof3tfcRljgAAUITKI"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FoodLodge uses your location to show food listings near you.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5c842"
      },
      "package": "app.foodlodge",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBXwuaCqvL03XGToZof3tfcRljgAAUITKI"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8a80d2df-7e26-4113-b170-9c4c030b9ebb"
      }
    },
    "owner": "olah07",
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FoodLodge uses your location to show food listings near you."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.app.foodlodge",
          "enableGooglePay": false
        }
      ],
      "react-native-purchases"
    ]
  }
}
